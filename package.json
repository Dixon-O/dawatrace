{
  "name": "dawatrace",
  "version": "1.0.0",
  "type": "module",
  "description": "Blockchain-based pharmaceutical supply chain verification platform for Kenya",
  "scripts": {
    "node": "npx hardhat node",
    "compile": "npx hardhat compile",
    "deploy": "npx hardhat run scripts/deploy.js --network localhost",
    "deploy:local": "npx hardhat run scripts/deploy.js --network localhost",
    "test": "npx hardhat test",
    "serve": "npx -y serve -s frontend -l 3000",
    "clean": "npx hardhat clean"
  },
  "keywords": [
    "blockchain",
    "pharmaceutical",
    "supply-chain",
    "solidity",
    "polygon",
    "anti-counterfeit"
  ],
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^6.1.2",
    "hardhat": "^2.28.6"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1"
  }
}
